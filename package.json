{
  "name": "illustrator-saas",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "db:migrate:local": "npm run db:migrate:local --workspace=apps/api",
    "db:migrate:remote": "npm run db:migrate:remote --workspace=apps/api",
    "deploy:api": "npm run deploy --workspace=apps/api",
    "deploy:web": "npm run deploy --workspace=apps/web",
    "deploy": "npm run deploy:api && npm run deploy:web"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.7.2",
    "wrangler": "^4.80.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
