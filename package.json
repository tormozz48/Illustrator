{
  "name": "illustrator",
  "version": "2.0.0",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "start:api": "node dist/api/main.js",
    "start:worker": "node dist/worker/main.js",
    "start:api:dev": "nest start api --watch",
    "start:worker:dev": "nest start worker --watch",
    "build": "nest build api && nest build worker",
    "build:web": "npm run build --workspace=apps/web",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "db:migration:create": "npx sequelize-cli migration:generate --name",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@google/genai": "^1.0.0",
    "@nestjs/bullmq": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/serve-static": "^5.0.0",
    "@nestjs/sequelize": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.0",
    "jimp": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.0",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sequelize": "^6.37.0",
    "sequelize-typescript": "^2.1.6",
    "socket.io": "^4.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "sequelize-cli": "^6.6.2",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0"
  }
}
